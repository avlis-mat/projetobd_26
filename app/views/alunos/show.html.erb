<div class="page-header">
  <h1><%= @aluno.usuario&.nome %></h1>
  <div class="actions">
    <%= link_to "Editar", edit_aluno_path(@aluno), class: "btn btn-primary" %>
    <%= link_to "Voltar", alunos_path, class: "btn btn-secondary" %>
  </div>
</div>

<div class="card">
  <%= render @aluno %>

  <h2 style="margin-top: 20px;">Turmas Matriculadas</h2>
  <% if @turmas.any? %>
    <% @turmas.each do |t| %>
      <p style="padding: 6px 0; border-bottom: 1px solid #eee;">
        <%= t.materia&.nome %> —
        Turma <%= t.codigo %> |
        <%= t.turno %> (<%= t.horario %>)
      </p>
    <% end %>
  <% else %>
    <p style="color:#888;">Nenhuma turma matriculada.</p>
  <% end %>
</div>