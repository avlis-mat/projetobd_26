<div class="page-header">
  <h1> <%= @formulario.titulo %></h1>
  <%= link_to "Voltar", formularios_path, class: "btn btn-secondary" %>
</div>

<div class="card" style="margin-bottom: 16px;">
  <div class="detail-row">
    <span class="detail-label">Turma:</span>
    Turma <%= @formulario.turma&.codigo %> — <%= @formulario.turma&.materia&.nome %>
  </div>
  <div class="detail-row">
    <span class="detail-label">Instruções:</span>
    <%= @formulario.instrucoes %>
  </div>
  <div class="detail-row">
    <span class="detail-label">Disponível até:</span>
    <%= @formulario.data_fim&.strftime("%d/%m/%Y") %>
  </div>
</div>

<% if @ja_respondidas.any? %>
  <div class="flash-notice" style="margin-bottom: 16px;">
     Você já respondeu <%= @ja_respondidas.count %> de <%= @questoes.count %> questões.
    As respostas anteriores serão atualizadas se você enviar novamente.
  </div>
<% end %>

<%= form_with url: enviar_respostas_formulario_path(@formulario), method: :post do |f| %>
  <% @questoes.each_with_index do |questao, i| %>
    <div class="card" style="margin-bottom: 16px;">
      <div style="display: flex; align-items: flex-start; gap: 12px;">
        <span style="background: #1a3a5c; color: white; border-radius: 50%;
                     width: 28px; height: 28px; display: flex; align-items: center;
                     justify-content: center; font-size: 13px; flex-shrink: 0;">
          <%= i + 1 %>
        </span>
        <div style="flex: 1;">
          <p style="font-weight: bold; margin-bottom: 12px;">
            <%= questao.enunciado %>
          </p>
          <div class="form-group">
            <textarea name="respostas[<%= questao.id %>]"
                      placeholder="Digite sua resposta..."
                      style="width:100%; padding:8px; border:1px solid #ccc;
                             border-radius:5px; height:80px; resize:vertical;"
            ><%= @ja_respondidas.include?(questao.id) ?
                Respostum.find_by(
                  idaluno: current_aluno.idusuario,
                  idformulario: @formulario.id,
                  idquestao: questao.id
                )&.conteudo : "" %></textarea>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div style="display: flex; gap: 12px; margin-top: 8px;">
    <%= f.submit " Enviar Respostas", class: "btn btn-success" %>
    <%= link_to "Cancelar", formularios_path, class: "btn btn-secondary" %>
  </div>
<% end %>