<div class="detail-row"><span class="detail-label">Título:</span>       <%= formulario.titulo %></div>
<div class="detail-row"><span class="detail-label">Status:</span>       <%= formulario.status %></div>
<div class="detail-row"><span class="detail-label">Turma:</span>        <%= formulario.turma&.codigo %></div>
<div class="detail-row"><span class="detail-label">Modelo:</span>       <%= formulario.modelo&.nome %></div>
<div class="detail-row"><span class="detail-label">Criado por:</span>   <%= formulario.usuario&.nome %></div>
<div class="detail-row"><span class="detail-label">Instruções:</span>   <%= formulario.instrucoes %></div>
<div class="detail-row"><span class="detail-label">Destinatário:</span> <%= formulario.destinatario %></div>
<div class="detail-row"><span class="detail-label">Início:</span>       <%= formulario.data_inicio&.strftime("%d/%m/%Y") %></div>
<div class="detail-row"><span class="detail-label">Fim:</span>          <%= formulario.data_fim&.strftime("%d/%m/%Y") %></div>