  </div>

  <div>
    <%= form.label :instrucoes, style: "display: block" %>
    <%= form.text_field :instrucoes %>
  </div>

  <div>
    <%= form.label :destinatario, style: "display: block" %>
    <%= form.text_field :destinatario %>
  </div>

  <div>
    <%= form.label :idUsuario, style: "display: block" %>
    <%= form.number_field :idUsuario %>
  </div>

  <div>
    <%= form.label :idTurma, style: "display: block" %>
