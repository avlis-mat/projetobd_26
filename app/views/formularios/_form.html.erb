<%= form_with model: formulario, multipart: true do |f| %>
  <div class="form-group">
    <%= f.label :titulo, "Título" %>
    <%= f.text_field :titulo %>
  </div>
  <div class="form-group">
    <%= f.label :status, "Status" %>
    <%= f.select :status, ["aberto", "encerrado", "rascunho"], { prompt: "Selecione" } %>
  </div>
  <div class="form-group">
    <%= f.label :idusuario, "Criado por" %>
    <%= f.select :idusuario, Usuario.all.map { |u| [u.nome, u.id] }, { prompt: "Selecione" } %>
  </div>
  <div class="form-group">
    <%= f.label :idturma, "Turma" %>
    <%= f.select :idturma, Turma.all.map { |t| ["Turma #{t.codigo} — #{t.materia&.nome}", t.id] }, { prompt: "Selecione" } %>
  </div>
  <div class="form-group">
    <%= f.label :idmodelo, "Modelo" %>
    <%= f.select :idmodelo, Modelo.all.map { |m| [m.nome, m.id] }, { prompt: "Selecione" } %>
  </div>
  <div class="form-group">
    <%= f.label :instrucoes, "Instruções" %>
    <%= f.text_area :instrucoes %>
  </div>
  <div class="form-group">
    <%= f.label :destinatario, "Destinatário" %>
    <%= f.text_field :destinatario, placeholder: "alunos" %>
  </div>
  <div class="form-group">
    <%= f.label :data_inicio, "Data de Início" %>
    <%= f.date_field :data_inicio %>
  </div>
  <div class="form-group">
    <%= f.label :data_fim, "Data de Fim" %>
    <%= f.date_field :data_fim %>
  </div>
  <div class="form-group">
    <%= f.label :arquivo, "Anexar PDF/Imagem" %>
    <%= f.file_field :arquivo %>
  </div>
  <%= f.submit "Salvar", class: "btn btn-success" %>
  <%= link_to "Cancelar", formularios_path, class: "btn btn-secondary" %>
<% end %>