<div class="page-header">
  <h1> Minhas Respostas</h1>
</div>

<% if @respostas_por_formulario.empty? %>
  <div class="card">
    <p style="color:#888; text-align:center; padding: 20px;">
      Você ainda não respondeu nenhum formulário.
      <%= link_to "Ver formulários disponíveis", formularios_path %>
    </p>
  </div>
<% else %>
  <% @respostas_por_formulario.each do |formulario, respostas| %>
    <div class="card" style="margin-bottom: 24px;">

      <div style="display:flex; justify-content:space-between; align-items:center;
                  margin-bottom: 16px; padding-bottom: 12px; border-bottom: 2px solid #1a3a5c;">
        <div>
          <h2 style="margin-bottom: 4px;"><%= formulario&.titulo %></h2>
          <span style="color:#888; font-size:13px;">
            Turma <%= formulario&.turma&.codigo %> —
            <%= formulario&.turma&.materia&.nome %>
          </span>
        </div>
        <span style="background: #1a3a5c; color:white; padding: 4px 12px;
                     border-radius: 12px; font-size: 13px;">
          <%= respostas.count %> resposta(s)
        </span>
      </div>

      <% respostas.each_with_index do |resposta, i| %>
        <div style="padding: 12px 0; border-bottom: 1px solid #eee;">
          <div style="display:flex; gap: 12px; align-items: flex-start;">
            <span style="background: #f0f4f8; color: #1a3a5c; border-radius: 50%;
                         width: 26px; height: 26px; display:flex; align-items:center;
                         justify-content:center; font-size:12px; flex-shrink:0;
                         font-weight:bold;">
              <%= i + 1 %>
            </span>
            <div style="flex:1;">
              <p style="font-weight:bold; color:#555; font-size:13px; margin-bottom:6px;">
                <%= resposta.questao&.enunciado %>
              </p>
              <p style="background:#f9f9f9; padding: 8px 12px; border-radius:5px;
                        border-left: 3px solid #1a3a5c; font-size:14px;">
                <%= resposta.conteudo %>
              </p>
              <p style="color:#aaa; font-size:12px; margin-top:4px;">
                Respondido em: <%= resposta.respondido_em&.strftime("%d/%m/%Y às %H:%M") %>
              </p>
            </div>
          </div>
        </div>
      <% end %>

      <div style="margin-top: 12px;">
        <%= link_to " Reeditar respostas",
            responder_formulario_path(formulario),
            class: "btn btn-primary btn-sm" %>
      </div>

    </div>
  <% end %>
<% end %>