<div class="page-header">
  <h1><%= @departamento.nome %></h1>
  <div class="actions">
    <%= link_to "Editar", edit_departamento_path(@departamento), class: "btn btn-primary" %>
    <%= link_to "Voltar", departamentos_path, class: "btn btn-secondary" %>
  </div>
</div>
<div class="card">
  <%= render @departamento %>

  <h2 style="margin-top: 20px;">Matérias</h2>
  <% if @materias.any? %>
    <% @materias.each do |m| %>
      <div style="padding: 8px 0; border-bottom: 1px solid #eee;">
        <strong><%= m.nome %></strong>
        <span style="color:#888; font-size:13px; margin-left:8px;">
          <%= m.codigo %> — <%= m.semestre %>
        </span>

        <% if m.turmas.any? %>
          <div style="margin-top: 6px; padding-left: 16px;">
            <% m.turmas.each do |t| %>
              <span style="font-size:13px; color:#555; display:block;">
                └ Turma <%= t.codigo %> | <%= t.turno %> (<%= t.horario %>)
              </span>
            <% end %>
          </div>
        <% else %>
          <span style="font-size:12px; color:#aaa; margin-left:8px;">
            (sem turmas)
          </span>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p style="color:#888; margin-top:8px;">Nenhuma matéria associada a este departamento.</p>
  <% end %>
</div>