<%= form_with(model: questao) do |form| %>
  <% if questao.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(questao.errors.count, "error") %> prohibited this questao from being saved:</h2>

      <ul>
        <% questao.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :Enunciado, style: "display: block" %>
    <%= form.text_field :Enunciado %>
  </div>

  <div>
    <%= form.label :Versao, style: "display: block" %>
    <%= form.text_field :Versao %>
  </div>

  <div>
    <%= form.label :Status, style: "display: block" %>
    <%= form.text_field :Status %>
  </div>

  <div>
    <%= form.label :Criado_em, style: "display: block" %>
    <%= form.datetime_field :Criado_em %>
  </div>

  <div>
    <%= form.label :Atualizado_em, style: "display: block" %>
    <%= form.datetime_field :Atualizado_em %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
