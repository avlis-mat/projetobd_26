<div class="page-header">
  <h1>Matérias</h1>
  <%= link_to "Nova Matéria", new_materium_path, class: "btn btn-primary" %>
</div>
<table>
  <thead>
    <tr><th>ID</th><th>Nome</th><th>Código</th><th>Semestre</th><th>Departamento</th><th>Ações</th></tr>
  </thead>
  <tbody>
    <% @materia.each do |m| %>
      <tr>
        <td><%= m.id %></td>
        <td><%= m.nome %></td>
        <td><%= m.codigo %></td>
        <td><%= m.semestre %></td>
        <td><%= m.departamento&.nome %></td>
        <td class="actions">
          <%= link_to "Ver",    materium_path(m),      class: "btn btn-secondary btn-sm" %>
          <%= link_to "Editar", edit_materium_path(m), class: "btn btn-primary btn-sm" %>
          <%= link_to "Excluir", materium_path(m),
              data: { turbo_method: :delete, turbo_confirm: "Confirma exclusão?" },
              class: "btn btn-danger btn-sm" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>