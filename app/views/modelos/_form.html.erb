<%= form_with model: modelo do |f| %>
  <div class="form-group">
    <%= f.label :nome, "Nome" %>
    <%= f.text_field :nome %>
  </div>
  <div class="form-group">
    <%= f.label :descricao, "Descrição" %>
    <%= f.text_area :descricao %>
  </div>
  <div class="form-group">
    <%= f.label :versao, "Versão" %>
    <%= f.text_field :versao, placeholder: "Ex: 1.0" %>
  </div>
  <div class="form-group">
    <%= f.label :status, "Status" %>
    <%= f.select :status, ["ativo", "inativo"], { prompt: "Selecione" } %>
  </div>
  <div class="form-group">
    <%= f.label :idusuario, "Criado por" %>
    <%= f.select :idusuario, Usuario.all.map { |u| [u.nome, u.id] }, { prompt: "Selecione" } %>
  </div>
  <div class="form-group">
    <label>Questões</label>
    <% Questao.all.each do |q| %>
      <div style="margin: 4px 0;">
        <input type="checkbox" name="questao_ids[]" value="<%= q.id %>"
          <%= "checked" if modelo.persisted? && modelo.questaos.include?(q) %>>
        <%= q.enunciado %>
      </div>
    <% end %>
  </div>
  <%= f.submit "Salvar", class: "btn btn-success" %>
  <%= link_to "Cancelar", modelos_path, class: "btn btn-secondary" %>
<% end %>