<%= form_with model: turma do |f| %>
  <div class="form-group">
    <%= f.label :idmateria, "Matéria" %>
    <%= f.select :idmateria, Materium.all.map { |m| [m.nome, m.id] }, { prompt: "Selecione" } %>
  </div>
  <div class="form-group">
    <%= f.label :turno, "Turno" %>
    <%= f.select :turno, ["Matutino", "Vespertino", "Noturno"], { prompt: "Selecione" } %>
  </div>
  <div class="form-group">
    <%= f.label :horario, "Horário" %>
    <%= f.text_field :horario, placeholder: "Ex: 19h-21h" %>
  </div>
  <div class="form-group">
    <%= f.label :codigo, "Código" %>
    <%= f.number_field :codigo %>
  </div>
  <%= f.submit "Salvar", class: "btn btn-success" %>
  <%= link_to "Cancelar", turmas_path, class: "btn btn-secondary" %>
<% end %>